{
  "name": "nodejs-ts-template",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "A NodeJS Typescript Express Template to quickly start with a new project",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc --build",
    "start": "node ./dist/index.js",
    "clean": "rimraf ./dist",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "dotenv-flow": "^4.1.0",
    "express": "^5.1.0",
    "morgan": "^1.10.1",
    "prisma": "^6.16.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.3.1",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
